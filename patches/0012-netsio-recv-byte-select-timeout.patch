+        FD_ZERO(&rfds);
+        FD_SET(fds0[0], &rfds);
+        tv.tv_sec = NETSIO_RECV_BYTE_TIMEOUT_SEC;
+        tv.tv_usec = 0;
+
+        sel = select(fds0[0] + 1, &rfds, NULL, NULL, &tv);
+        if (sel < 0) {
+            if (errno == EINTR)
+                continue;
 #ifdef DEBUG
-        Log_print("netsio: read from rx FIFO");

+            return -1;
+        }
+        if (sel == 0) {
+#ifdef DEBUG
+            Log_print("netsio: recv_byte: select timeout waiting for pipe data");
+#endif
+            return -1;
+        }
+
+        ssize_t n = read(fds0[0], b, 1);
+        if (n < 0) {
+            if (errno == EINTR)
+                continue;
+#ifdef DEBUG
+            Log_print("netsio: read from rx FIFO");
+#endif
+            return -1;
+        }
+        if (n == 0)
+            return -1; /* FIFO closed? */
 #ifdef DEBUG2

+    /* Enlarge pipe buffer where supported. If the rx thread blocks on write()
+     * to the emulator FIFO while netsio_sync_wait is still 1, the emulator can
+     * deadlock in netsio_wait_for_sync() (nothing drains fds0[0]). */
+#ifdef F_SETPIPE_SZ
+    {
+        int sz = 1 << 20; /* 1 MiB on Linux; best-effort elsewhere */
+        if (fcntl(fds0[1], F_SETPIPE_SZ, sz) != -1)
+            (void)fcntl(fds0[0], F_SETPIPE_SZ, sz);
+    }
+#endif
+

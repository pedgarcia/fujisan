+/* Drain all pending bytes in the FujiNet->emulator pipe.
+ * Temporarily sets O_NONBLOCK, reads until empty, then restores flags. */
+void netsio_flush_fifo(void)
+{
+    if (fds0[0] < 0)
+        return;
+    int flags = fcntl(fds0[0], F_GETFL, 0);
+    fcntl(fds0[0], F_SETFL, flags | O_NONBLOCK);
+    {
+        uint8_t discard[256];
+        while (read(fds0[0], discard, sizeof(discard)) > 0)
+            ;
+    }
+    fcntl(fds0[0], F_SETFL, flags);
+}

diff --git a/src/pokey.c b/src/pokey.c
index ae349fe8..04b6d625 100644
--- a/src/pokey.c
+++ b/src/pokey.c
@@ -167,11 +167,22 @@ static void Update_Counter(int chan_mask);
 
 static int POKEY_siocheck(void)
 {
-	return (((POKEY_AUDF[POKEY_CHAN3] == 0x28 || POKEY_AUDF[POKEY_CHAN3] == 0x10
-	        || POKEY_AUDF[POKEY_CHAN3] == 0x08 || POKEY_AUDF[POKEY_CHAN3] == 0x0a)
-		&& POKEY_AUDF[POKEY_CHAN4] == 0x00) /* intelligent peripherals speeds */
+	int intelligent_peripheral_speed =
+		((POKEY_AUDF[POKEY_CHAN3] == 0x28 || POKEY_AUDF[POKEY_CHAN3] == 0x10
+		 || POKEY_AUDF[POKEY_CHAN3] == 0x08 || POKEY_AUDF[POKEY_CHAN3] == 0x0a)
+		&& POKEY_AUDF[POKEY_CHAN4] == 0x00); /* intelligent peripherals speeds */
+#ifdef NETSIO
+	/* When netsio is active, accept any divisor 1..40 (0x01..0x28) so that
+	 * FujiNet high-speed transfers at divisors other than the four standard
+	 * values are also recognised as serial output. Port of mozzwald/atari800@1ce4be5. */
+	if (netsio_enabled
+	    && POKEY_AUDF[POKEY_CHAN3] > 0x00 && POKEY_AUDF[POKEY_CHAN3] <= 0x28
+	    && POKEY_AUDF[POKEY_CHAN4] == 0x00)
+		intelligent_peripheral_speed = 1;
+#endif /* NETSIO */
+	return ((intelligent_peripheral_speed
 		|| (POKEY_SKCTL & 0x78) == 0x28) /* cassette save mode */
-		&& (POKEY_AUDCTL[0] & 0x28) == 0x28;
+		&& (POKEY_AUDCTL[0] & 0x28) == 0x28);
 }
 

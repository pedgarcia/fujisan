From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Fujisan Developer <fujisan@atari>
Date: Wed, 9 Apr 2026 00:00:00 +0000
Subject: [PATCH] netsio: recover stale SIO state when a new command frame starts

When TransferStatus is SIO_StatusRead (0x2) or another mid-transaction state
and the emulated Atari asserts a new SIO command frame (e.g. immediately after
Atari800_Coldstart without clearing SIO static state), NetSIO and FujiNet-PC
can disagree on CMD/data phase. That produced "Unexpected command frame at
state 2" spam and could lead to crashes.

Add netsio_recover_stale_sio_transaction() to clear netsio_sync_wait, reset
netsio_next_write_size, deassert CMD if still marked on, and non-blockingly
drain stale bytes from the RX pipe so the next NetSIO_GetByte does not consume
an ACK from a defunct transfer.

Call it from SIO_SwitchCommandFrame(true) when netsio_enabled and the
unexpected-frame condition already applied (same predicate as the log line).

Applies after 0014 (TransferToNetsio): sio.c hunk must include TransferToNetsio = 0.
---
 src/netsio.h |  2 ++
 src/netsio.c | 33 +++++++++++++++++++++++++++++++++
 src/sio.c    | 17 +++++++++++------
 3 files changed, 43 insertions(+), 3 deletions(-)

diff --git a/src/netsio.h b/src/netsio.h
--- a/src/netsio.h
+++ b/src/netsio.h
@@ -85,6 +85,8 @@ int netsio_motor_off(void);
 void netsio_poll(void);
 void netsio_wait_for_sync(void);
+/* Clear stale NetSIO state when SIO begins a new command frame mid-transaction (e.g. after cold boot). */
+void netsio_recover_stale_sio_transaction(void);
 int netsio_available(void);
 int netsio_cold_reset(void);
 int netsio_warm_reset(void);

diff --git a/src/netsio.c b/src/netsio.c
--- a/src/netsio.c
+++ b/src/netsio.c
@@ -340,6 +340,39 @@ void netsio_wait_for_sync(void)
     pthread_mutex_unlock(&netsio_sync_mutex);
 }
 
+/* Called from SIO when a new command frame starts while TransferStatus is not idle
+ * (e.g. SIO_StatusRead after reset). Resyncs CMD line, clears sync wait, drains stale
+ * RX bytes so the next NetSIO_GetByte does not consume an ACK from a defunct transfer. */
+void netsio_recover_stale_sio_transaction(void)
+{
+    if (!netsio_enabled)
+        return;
+
+    pthread_mutex_lock(&netsio_sync_mutex);
+    netsio_sync_wait = 0;
+    pthread_mutex_unlock(&netsio_sync_mutex);
+
+    netsio_next_write_size = 0;
+
+    if (netsio_cmd_state) {
+        netsio_cmd_off();
+        netsio_cmd_state = 0;
+    }
+
+    /* Drain stale bytes from the FujiNet->emulator pipe (POSIX builds only). */
+    if (fds0[0] >= 0) {
+        int flags = fcntl(fds0[0], F_GETFL, 0);
+        if (flags >= 0) {
+            unsigned char discard[512];
+            fcntl(fds0[0], F_SETFL, flags | O_NONBLOCK);
+            while (read(fds0[0], discard, sizeof(discard)) > 0)
+                ;
+            fcntl(fds0[0], F_SETFL, flags);
+        }
+    }
+}
+
+
 /* Return number of bytes waiting from FujiNet to emulator */
 int netsio_available(void) {
     int avail = 0;

diff --git a/src/sio.c b/src/sio.c
--- a/src/sio.c
+++ b/src/sio.c
@@ -1534,12 +1534,17 @@ void SIO_SwitchCommandFrame(int onoff)
 #ifdef NETSIO
 		TransferToNetsio = 0;
 #endif /* NETSIO */
-		if (TransferStatus != SIO_NoFrame) 
+		if (TransferStatus != SIO_NoFrame) {
 #ifdef NETSIO
 			/* With NetSIO we do not track end of read frame, SIO_ReadFrame is last status */
-			if (netsio_enabled && TransferStatus != SIO_ReadFrame)
+			if (netsio_enabled && TransferStatus != SIO_ReadFrame) {
+				Log_print("Unexpected command frame at state %x - recovering NetSIO.", TransferStatus);
+				netsio_recover_stale_sio_transaction();
+			}
+#else
+			Log_print("Unexpected command frame at state %x.", TransferStatus);
 #endif /* NETSIO */
-				Log_print("Unexpected command frame at state %x.", TransferStatus);
+		}
 		CommandIndex = 0;
 		DataIndex = 0;
 		ExpectedBytes = 5;
